---
import BaseLayout from '../layouts/BaseLayout.astro';
import LobbyControlCenter from '../components/LobbyControlCenter.astro';
import '../styles/deal-desk.css';
import '../styles/method-manager.css';
import '../styles/control-center.css';

const buildVersion = String(
  import.meta.env.VERCEL_GIT_COMMIT_SHA
  || import.meta.env.GITHUB_SHA
  || Date.now(),
).slice(0, 12);
---

<BaseLayout
  title="Lobby Control Center | The 420 Lobby"
  description="Private website and method controls for The 420 Lobby."
  noindex
  chrome={false}
>
  <LobbyControlCenter />
</BaseLayout>

<style is:global>
  @media (min-width: 1101px) {
    .lobby-control-center .desk-selection-panel {
      top: 6rem;
    }
  }
</style>

<script is:inline>
  globalThis.CSS ||= {};
  if (typeof globalThis.CSS.escape !== 'function') {
    globalThis.CSS.escape = (value) => String(value).replace(/[^a-zA-Z0-9_-]/g, '\\$&');
  }
</script>
<script src={`/deal-desk.js?v=${buildVersion}`} defer></script>
<script src={`/control-center.js?v=${buildVersion}`} defer></script>
