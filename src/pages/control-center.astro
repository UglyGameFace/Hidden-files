---
import BaseLayout from '../layouts/BaseLayout.astro';
import LobbyControlCenter from '../components/LobbyControlCenter.astro';
import '../styles/deal-desk.css';
import '../styles/method-manager.css';
import '../styles/control-center.css';
---

<BaseLayout
  title="Lobby Control Center | The 420 Lobby"
  description="Private website and method controls for The 420 Lobby."
  noindex
>
  <LobbyControlCenter />
</BaseLayout>

<style is:global>
  @media (min-width: 1101px) {
    .lobby-control-center .desk-selection-panel {
      top: 6rem;
    }
  }
</style>

<script src="/deal-desk.js" defer></script>
<script src="/control-center.js" defer></script>
