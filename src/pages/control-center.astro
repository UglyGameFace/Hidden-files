---
import BaseLayout from '../layouts/BaseLayout.astro';
import LobbyControlCenter from '../components/LobbyControlCenter.astro';
import '../styles/deal-desk.css';
import '../styles/method-manager.css';
import '../styles/control-center.css';
---

<BaseLayout
  title="Lobby Control Center | The 420 Lobby"
  description="Private website and method controls for The 420 Lobby."
  noindex
  chrome={false}
>
  <LobbyControlCenter />
</BaseLayout>

<style is:global>
  @media (min-width: 1101px) {
    .lobby-control-center .desk-selection-panel {
      top: 6rem;
    }
  }
</style>

<script is:inline>
  if (!window.CSS) window.CSS = {};
  if (typeof window.CSS.escape !== 'function') {
    window.CSS.escape = function (value) {
      return String(value).replace(/[^a-zA-Z0-9_-]/g, function (character) {
        return '\\' + character;
      });
    };
  }
</script>
<script>
  import '../scripts/deal-desk.js';
  import '../scripts/control-center.js';
</script>
