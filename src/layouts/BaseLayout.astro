---
import '../styles/global.css';
import '../styles/live-status.css';
import '../styles/home-compact.css';
import Sidebar from '../components/Sidebar.astro';
import MobileHeader from '../components/MobileHeader.astro';
import Footer from '../components/Footer.astro';
import { SITE, type CategoryKey } from '../config';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  activeCategory?: CategoryKey | 'all';
  article?: boolean;
  noindex?: boolean;
}

const {
  title = SITE.title,
  description = SITE.description,
  image = '/og-card.svg',
  activeCategory = 'all',
  article = false,
  noindex = false,
} = Astro.props;
const canonical = new URL(Astro.url.pathname, SITE.siteUrl);
const ogImage = new URL(image, SITE.siteUrl);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#090b0e" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow, noarchive" />}
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content={article ? 'article' : 'website'} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={SITE.name} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <Sidebar activeCategory={activeCategory} />
    <MobileHeader />
    <div class="site-shell">
      <main id="main-content"><slot /></main>
      <Footer />
    </div>
  </body>
</html>
