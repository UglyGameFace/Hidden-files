---
import Brand from './Brand.astro';
import Icon from './Icon.astro';
import { CATEGORY_ENTRIES, SITE, SITE_SETTINGS, type CategoryKey } from '../config';

interface Props {
  activeCategory?: CategoryKey | 'all';
}
const { activeCategory = 'all' } = Astro.props;
---

<aside class="site-sidebar" aria-label="Primary navigation">
  <div class="sidebar-brand-wrap"><Brand /></div>

  <nav class="sidebar-nav">
    <p class="sidebar-section-label">{SITE_SETTINGS.navigation.browseLabel}</p>
    <a class:list={['sidebar-link', { active: activeCategory === 'all' }]} href="/">
      <span class="sidebar-icon"><Icon name="home" /></span>
      <span class="sidebar-link-copy"><strong>{SITE_SETTINGS.navigation.allHacksLabel}</strong><small>{SITE_SETTINGS.navigation.allHacksDescription}</small></span>
      <span class="rail-label">All</span>
    </a>

    {CATEGORY_ENTRIES.map(([key, category]) => (
      <a
        class:list={['sidebar-link', `accent-${category.accent}`, { active: activeCategory === key }]}
        href={`/?category=${key}#library`}
      >
        <span class="sidebar-icon"><Icon name={category.icon} /></span>
        <span class="sidebar-link-copy"><strong>{category.label}</strong><small>{category.description}</small></span>
        <span class="rail-label">{category.shortLabel}</span>
      </a>
    ))}
  </nav>

  <div class="sidebar-promo">
    <div class="promo-status"><span></span> {SITE_SETTINGS.discord.sidebarStatus}</div>
    <strong>{SITE_SETTINGS.discord.sidebarTitle}</strong>
    <p>{SITE_SETTINGS.discord.sidebarDescription}</p>
    <a href={SITE.discordInvite} target="_blank" rel="noreferrer" class="discord-button sidebar-discord">
      <Icon name="discord" />
      <span class="desktop-only">{SITE_SETTINGS.discord.sidebarButtonLabel}</span>
      <span class="sr-only tablet-only">{SITE_SETTINGS.discord.sidebarButtonLabel}</span>
    </a>
  </div>
</aside>
