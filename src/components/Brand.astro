---
interface Props {
  compact?: boolean;
}
const { compact = false } = Astro.props;
---

<a href="/" class:list={["brand", { compact }]} aria-label="The 420 Lobby Money and Food Hacks home">
  <span class="brand-mark" aria-hidden="true">
    <span>420</span>
  </span>
  <span class="brand-copy">
    <strong>The 420 Lobby</strong>
    <small>Money &amp; Food Hacks</small>
  </span>
</a>
