# Public site settings
PUBLIC_DISCORD_INVITE_URL=https://discord.gg/your-permanent-invite
PUBLIC_SITE_URL=https://your-project.vercel.app

# Private Deal Desk settings
# Choose a strong password for /deal-desk.
DEAL_DESK_PASSWORD=replace-with-a-long-private-password
# Optional separate signing secret. If omitted, the password signs sessions.
DEAL_DESK_SESSION_SECRET=replace-with-a-random-long-secret
# Fine-grained GitHub token with Contents: Read and write for this repository only.
GITHUB_TOKEN=github_pat_replace_me

# Optional. Vercel normally supplies the repository owner/name automatically.
GITHUB_REPO_OWNER=UglyGameFace
GITHUB_REPO_NAME=Hidden-files
GITHUB_BRANCH=main
